      "boundElements": [],
      "updated": 1781175365631,
      "link": null,
      "locked": false,
      "text": "Space Colony Miner\nYou are in charge of a mining-colony on a distant planet.\nYou click on asteroids to collect resources.\n\nUpgrade:\nMining-drones: dig resources automaticly.\nCargo-ships: increase storage capacity so you can mine more offline.\n\nShip fly mechanic to upgrade center somewhere in space?\nStellar view so you can see cargo ships flying?\nMine in different regions",
      "fontSize": 20,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Space Colony Miner\nYou are in charge of a mining-colony on a distant planet.\nYou click on asteroids to collect resources.\n\nUpgrade:\nMining-drones: dig resources automaticly.\nCargo-ships: increase storage capacity so you can mine more offline.\n\nShip fly mechanic to upgrade center somewhere in space?\nStellar view so you can see cargo ships flying?\nMine in different regions",
      "autoResize": true,
      "lineHeight": 1.25
    },
